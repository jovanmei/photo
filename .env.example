# Storage Provider Configuration
# Choose storage provider: cloudinary or qiniu
VITE_STORAGE_PROVIDER=cloudinary

# Cloudinary Configuration
# Get these values from https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Optional: Cloudinary API Key (for server-side operations only)
# Do not expose this in client-side code
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Qiniu Cloud Configuration (七牛云)
# Get these values from https://portal.qiniu.com/
VITE_QINIU_ACCESS_KEY=your_access_key
VITE_QINIU_SECRET_KEY=your_secret_key
VITE_QINIU_BUCKET_NAME=your_bucket_name
VITE_QINIU_DOMAIN=https://your-domain.com
VITE_QINIU_REGION=z0

# Supabase Configuration (Alternative backend)
# VITE_SUPABASE_URL=your_supabase_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Firebase Configuration (Alternative backend)
# VITE_FIREBASE_API_KEY=your_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
